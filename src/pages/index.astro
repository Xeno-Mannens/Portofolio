---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
const experiences = (await getCollection("experience")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Layout title="Software Engineer Portfolio">
  {/* Hero Section */}
  <section
    class="min-h-[75vh] flex flex-col justify-center animate-in fade-in slide-in-from-bottom-8 duration-1000"
  >
    <div
      class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-500/10 text-indigo-300 text-sm font-medium w-fit mb-6 border border-indigo-500/20"
    >
      <span class="relative flex h-2 w-2">
        <span
          class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"
        ></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"
        ></span>
      </span>
      Available for new opportunities
    </div>

    <h1
      class="text-5xl md:text-7xl font-extrabold tracking-tight text-white mb-6 leading-tight"
    >
      Hi, I'm a <br />
      <span
        class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 via-cyan-400 to-teal-400"
        >Software Engineer</span
      >
    </h1>

    <p
      class="text-lg md:text-xl text-slate-400 max-w-2xl mb-10 leading-relaxed"
    >
      Specializing in backend systems and business apps. Currently working as an
      <strong class="text-slate-200"> Odoo Developer </strong> and actively
      <strong class="text-slate-200"> learning AI </strong> to build next-generation
      intelligent applications.
    </p>

    <div class="flex flex-wrap gap-4">
      <a
        href="#projects"
        class="px-6 py-3 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white font-medium transition-all shadow-[0_0_20px_rgba(79,70,229,0.3)] hover:shadow-[0_0_30px_rgba(79,70,229,0.5)]"
      >
        View My Work
      </a>
      <a
        href="mailto:hello@example.com"
        class="px-6 py-3 rounded-lg bg-slate-800 hover:bg-slate-700 text-slate-200 font-medium transition-colors border border-slate-700"
      >
        Get In Touch
      </a>
    </div>
  </section>

  {/* Experience Section */}
  <section id="experience" class="py-20 scroll-mt-16">
    <h2 class="text-3xl font-bold mb-10 text-white flex items-center gap-3">
      <span class="w-8 h-[2px] bg-indigo-500"></span>
      Experience
    </h2>

    <div class="space-y-6">
      {
        experiences.map((exp) => (
          <div class="p-6 rounded-2xl bg-white/[0.02] border border-white/[0.05] hover:border-indigo-500/30 transition-colors group">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
              <div>
                <h3 class="text-xl font-bold text-slate-200 group-hover:text-indigo-400 transition-colors">
                  {exp.data.role}
                </h3>
                <p class="text-slate-400">{exp.data.company}</p>
              </div>
              <div class="text-sm font-medium text-slate-500 bg-slate-800/50 px-3 py-1 rounded-full w-fit">
                {exp.data.period}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  {/* Projects Section */}
  <section id="projects" class="py-20 scroll-mt-16">
    <h2 class="text-3xl font-bold mb-10 text-white flex items-center gap-3">
      <span class="w-8 h-[2px] bg-cyan-500"></span>
      Selected Projects
    </h2>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        projects.map((project) => (
          <a
            href={project.data.link || "#"}
            class="group relative p-6 rounded-2xl bg-white/[0.02] border border-white/[0.05] hover:bg-white/[0.04] transition-all overflow-hidden flex flex-col h-full hover:-translate-y-1 hover:shadow-2xl hover:shadow-cyan-500/10"
          >
            <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/10 to-cyan-500/10 opacity-0 group-hover:opacity-100 transition-opacity" />

            <div class="relative z-10 flex-1">
              <h3 class="text-xl font-bold text-slate-200 mb-3 group-hover:text-cyan-400 transition-colors">
                {project.data.title}
              </h3>
              <p class="text-slate-400 text-sm leading-relaxed mb-6">
                {project.data.description}
              </p>
            </div>

            <div class="relative z-10 flex items-center text-sm font-medium text-indigo-400 group-hover:text-cyan-400 transition-colors">
              View Details{" "}
              <span class="ml-2 group-hover:translate-x-1 transition-transform">
                →
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  {/* Skills/AI snippet */}
  <section class="py-20">
    <div
      class="p-8 md:p-12 rounded-3xl bg-gradient-to-br from-indigo-900/40 to-slate-900 border border-indigo-500/20 relative overflow-hidden"
    >
      <div
        class="absolute top-0 right-0 -mt-20 -mr-20 w-64 h-64 bg-cyan-500/20 blur-[100px] rounded-full point-events-none"
      >
      </div>
      <div
        class="absolute bottom-0 left-0 -mb-20 -ml-20 w-64 h-64 bg-indigo-500/20 blur-[100px] rounded-full point-events-none"
      >
      </div>
    </div>
  </section>
</Layout>
