---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
    const projectsEntries = await getCollection("projects");
    return projectsEntries.map((entry) => ({
        params: { slug: entry.slug },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} | Portfolio`}>
    <article
        class="max-w-3xl mx-auto py-12 animate-in fade-in slide-in-from-bottom-8 duration-700"
    >
        <a
            href="/#projects"
            class="inline-flex items-center text-indigo-400 hover:text-indigo-300 transition-colors mb-8 font-medium"
        >
            <span class="mr-2">←</span> Back to Portfolio
        </a>

        <header class="mb-12">
            <h1
                class="text-4xl md:text-5xl font-extrabold text-white mb-6 leading-tight"
            >
                {entry.data.title}
            </h1>
            <p class="text-xl text-slate-400 mb-8 leading-relaxed">
                {entry.data.description}
            </p>

            <div class="flex flex-wrap gap-4 items-center">
                {
                    entry.data.link && (
                        <a
                            href={entry.data.link}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="px-6 py-2.5 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white font-medium transition-colors border border-transparent hover:border-indigo-400/50 flex flex-row items-center gap-2"
                        >
                            View Live
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="lucide lucide-external-link"
                            >
                                <>
                                    <path d="M15 3h6v6" />
                                    <path d="M10 14 21 3" />
                                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                                </>
                            </svg>
                        </a>
                    )
                }
                {
                    entry.data.github && (
                        <a
                            href={entry.data.github}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="px-6 py-2.5 rounded-lg bg-slate-800 hover:bg-slate-700 text-slate-200 font-medium transition-colors border border-slate-700 flex flex-row items-center gap-2"
                        >
                            GitHub
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="lucide lucide-github"
                            >
                                <>
                                    <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                                    <path d="M9 18c-4.51 2-5-2-7-2" />
                                </>
                            </svg>
                        </a>
                    )
                }
            </div>

            {
                entry.data.tags && entry.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mt-8 py-6 border-t border-white/10">
                        {entry.data.tags.map((tag: string) => (
                            <span class="px-3 py-1 rounded-full bg-slate-900 border border-slate-800 text-slate-300 text-sm">
                                {tag}
                            </span>
                        ))}
                    </div>
                )
            }
        </header>

        <div
            class="prose prose-invert prose-slate prose-indigo max-w-none
                prose-headings:font-bold prose-headings:text-slate-200
                prose-a:text-indigo-400 hover:prose-a:text-indigo-300
                prose-code:text-indigo-300 prose-code:bg-indigo-500/10 prose-code:px-1 prose-code:rounded
                prose-pre:bg-slate-900 prose-pre:border prose-pre:border-slate-800
                prose-img:rounded-xl"
        >
            <Content />
        </div>
    </article>
</Layout>
